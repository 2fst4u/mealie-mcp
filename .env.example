# Required
# Base URL of your Mealie instance (no trailing slash)
MEALIE_BASE_URL="https://mealie.example.com"

# Authentication (Static Token)
# Long-lived Mealie API token. Ignored when OAuth is configured.
MEALIE_API_TOKEN="your-long-lived-token"

# Authentication (OAuth2 Client Credentials)
# Setting these takes precedence over MEALIE_API_TOKEN
# MEALIE_OAUTH_TOKEN_URL="https://idp.example.com/oauth/token"
# MEALIE_OAUTH_CLIENT_ID="your-client-id"
# MEALIE_OAUTH_CLIENT_SECRET="your-client-secret"
# MEALIE_OAUTH_SCOPE="mealie"
# MEALIE_OAUTH_AUDIENCE="https://mealie.example.com"

# Tool Filtering & Safety
# When true, only expose GET endpoints. Great for a safe, read-only assistant.
# MEALIE_READ_ONLY=false
# Comma-separated allow-list of tool names or category slugs to expose (e.g. recipe,households_shopping_lists)
# MEALIE_TOOLS=""
# Comma-separated deny-list of tool names or category slugs to hide further
# MEALIE_EXCLUDE_TOOLS=""

# OpenAPI & Tool Configuration
# Skip the live OpenAPI fetch and use the snapshot bundled with the package
# MEALIE_USE_BUNDLED_SPEC=false
# Override where the OpenAPI schema is fetched from (defaults to MEALIE_BASE_URL/openapi.json)
# MEALIE_OPENAPI_URL=""
# Max length of generated tool names (clamped to 16-64). Lower if combined name exceeds limit.
# MEALIE_TOOL_NAME_MAX=50
# Per-request timeout in milliseconds
# MEALIE_TIMEOUT=60000
# Extra attempts for idempotent GET requests on network errors / 429 / 5xx (clamped 0-5; 0 disables)
# MEALIE_RETRIES=2
# Log each outgoing request (method, path, status) to stderr for troubleshooting
# MEALIE_DEBUG=false
# Optional Accept-Language header forwarded to Mealie (affects e.g. ingredient parsing locale)
# MEALIE_ACCEPT_LANGUAGE=""
